{
  "name": "LinkJoin",
  "description": "Organize and automatically open virtual meetings.",
  "version": "0.3.0",
  "manifest_version": 3,
  "browser_specific_settings": {
    "gecko": {
      "id": "{cb7a19c7-55b9-4572-814a-065263619278}",
      "strict_min_version": "128.0"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": ["alarms", "storage", "windows", "contextMenus", "notifications"],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://linkjoin.xyz/*", "http://localhost:5173/*"],
      "js": ["lj-detect.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://linkjoin.xyz/*", "http://localhost:5173/*"],
      "js": ["lj-auth-sync.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": ["https://mail.google.com/*", "https://linkjoin.xyz/*", "http://localhost:5173/*", "http://localhost:8000/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "/icons/logo-rounded.png",
      "32": "/icons/logo-rounded.png",
      "48": "/icons/logo-rounded.png",
      "128": "/icons/logo-rounded.png"
    }
  },
  "icons": {
    "16": "/icons/logo-rounded.png",
    "32": "/icons/logo-rounded.png",
    "48": "/icons/logo-rounded.png",
    "128": "/icons/logo-rounded.png"
  }
}
